  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::ScriptDialogue
  dialogueCanvas: {fileID: 776668790}
  textComponent: {fileID: 2078727939}
  lines:
  - speaker: 1
    text: Bienvenue!
    image: 0
  - speaker: 1
    text: "J\u2019esp\xE8re que tu vas bien ! Tu peux me rappeler ton nom\u202F?"
    image: 0
  - speaker: 0
    text: Salut, je m'appelle Nova
    image: 3
  - speaker: 1
    text: "Enchant\xE9e Nova! Je me pr\xE9sente Ella..."
    image: 0
  - speaker: 1
    text: "Aujourd'hui, ta mission : actionner les 3 leviers de commande\u202F!"
    image: 1
  - speaker: 1
    text: Ainsi, tu pourras ouvrir la porte.
    image: 0
  - speaker: 1
    text: "Super tu as compl\xE9t\xE9 la mission!"
    image: 0
  - speaker: 1
    text: "Tu peux ainsi te diriger vers la porte pour acc\xE9der au niveau suivant."
    image: 0
  delaisParLigne:
  - 10
  - 10
  - 10
  - 10
  - 10
  - 10
