  textComponent: {fileID: 1173555812}
  lines:
  - speaker: 1
    text: 'Woahhh '
    image: 0
  - speaker: 1
    text: Il y a tout plein de plantes ici !
    image: 0
  - speaker: 0
    text: Oui, on peut continuer maintenant ?
    image: 3
  - speaker: 1
    text: "Attention d\u2019\xE9viter la cam\xE9ra de surveillance !"
    image: 1
  - speaker: 0
    text: Uh oh
    image: 4
  - speaker: 1
    text: 'Nova regarde ! '
    image: 1
  - speaker: 1
    text: "C\u2019est le petit qui garde la porte. "
    image: 0
  - speaker: 1
    text: 'Tu pourrais nous laisser passer ? '
    image: 0
  - speaker: 1
    text: " Nova a vraiment besoin de passer pour sauver sa m\xE8re.  "
    image: 0
  - speaker: 1
    text: "On devrait pouvoir \xE9teindre le robot maintenant"
    image: 0
