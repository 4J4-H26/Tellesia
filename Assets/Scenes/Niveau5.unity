  m_GameObject: {fileID: 1320514457}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: bb323a5359cdd4542ae8351b0e425cdd, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::ScriptDialogue5
  dialogueCanvas: {fileID: 1674269932}
  textComponent: {fileID: 387545296}
  lines:
  - speaker: 0
    text: "Finalement, nous y voil\xE0."
    image: 3
  - speaker: 1
    text: "Es-tu pr\xEAte?"
    image: 0
  - speaker: 0
    text: "KARDIA. Arr\xEAte ce que tu fais, plein d\u2019humains meurent \xE0 cause
      de toi. "
    image: 3
  - speaker: 0
    text: "Ma M\xC8RE est en danger par ta faute!"
    image: 3
  - speaker: 2
    text: "\u2026 D\xE9sol\xE9, c\u2019est\u2026 c\u2019est de ma faute tout cela. "
    image: 6
  - speaker: 2
    text: "Je.. je ne veux plus faire de mal \xE0 personne. "
    image: 7
  - speaker: 0
    text: "\xC9pargne moi\u2026 s\u2019il te pla\xEEt\u2026 habitants\u2026 mourir "
    image: 0
  - speaker: 0
    text: "Je m\u2019excuse "
    image: 0
  - speaker: 0
    text: "\u2026 "
    image: 3
  - speaker: 1
    text: "C'est \xE0 toi de choisir, Nova."
    image: 0
  delaisParLigne:
