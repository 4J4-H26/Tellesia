--- !u!114 &158513500
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 158513496}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: ad395da0ce7b108478f8c1661ab12ce2, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::ScriptDialogue4
  dialogueCanvas: {fileID: 1305708339}
  textComponent: {fileID: 1253169813}
  lines:
  - speaker: 1
    text: "Le dernier niveau\u2026 avant la confrontation"
    image: 0
  - speaker: 0
    text: 'Oui, nous sommes presque rendus.  '
    image: 3
  - speaker: 0
    text: "Combien de temps reste-t-il avant d\u2019atteindre Kardia ? "
    image: 3
  - speaker: 1
    text: "Je ne sais pas\u2026"
    image: 0
  - speaker: 1
    text: "\xE7a fait longtemps que nous sommes en train de descendre dans le vaisseau. "
    image: 0
  - speaker: 0
    text: "Encore la foutue Tellesia\u2026 "
    image: 3
  - speaker: 0
    text: 'Et ces symboles signifient quoi ? '
    image: 3
  - speaker: 1
    text: '[quelque chose en rapport de language des extraterrestres) '
    image: 0
  - speaker: 0
    text: 'Oups. '
    image: 3
  - speaker: 1
    text: "Attention d\u2019\xE9viter la cam\xE9ra de surveillance ! "
    image: 1
  - speaker: 1
    text: "On y est presque, tu vas bient\xF4t pouvoir [venger] ta m\xE8re "
    image: 0
  delaisParLigne: []
  textSpeed: 0
  buttonNext: {fileID: 266786196}
  nom: {fileID: 568588775}
  nova: {fileID: 211570012}
  autoNext: 1
