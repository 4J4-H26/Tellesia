  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 070b79d0b927e4c48aff19bf3da64b89, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::ScriptDialogue
  dialogueCanvas: {fileID: 776668790}
  textComponent: {fileID: 2078727939}
  lines:
  - speaker: 1
    text: "Bienvenue \xE0 bord du vaisseau Gryo !"
    image: 0
  - speaker: 1
    text: "Permets-moi de me pr\xE9senter : Ella, ton alli\xE9. Rappelle-moi ton
      nom, s'il te pla\xEEt."
    image: 0
  - speaker: 0
    text: "Salut Ella, Nova. Enchant\xE9(e)."
    image: 3
  - speaker: 1
    text: "Enchant\xE9(e), Nova. Compte sur moi pour te guider."
    image: 0
  - speaker: 1
    text: "Pour te d\xE9placer, utilise les touches WASD ou les fl\xE8ches du clavier."
    image: 1
  - speaker: 1
    text: "Aujourd'hui, ta mission : actionner les 3 leviers de commande\u202F!"
    image: 0
  - speaker: 1
    text: Utilise la touche E du clavier pour interagir avec les leviers de commande.
    image: 0
  - speaker: 1
    text: Ainsi, tu pourras ouvrir la porte.
    image: 0
  - speaker: 1
    text: "Super ! Tu as compl\xE9t\xE9 la mission. "
    image: 0
  - speaker: 1
    text: "Tu peux maintenant te rendre \xE0 la porte pour acc\xE9der au niveau suivant."
    image: 1
  delaisParLigne:
  - 10
  - 10
  - 10
  - 10
  - 10
  - 10
  - 10
  textSpeed: 0.025
  buttonNext: {fileID: 1896001656}
  nom: {fileID: 508151613}
  nova: {fileID: 1003329857}
  autoNext: 1
  ImageSpriteElla1: {fileID: 870308142}
  ImageSpriteNova1: {fileID: 1031547762}
